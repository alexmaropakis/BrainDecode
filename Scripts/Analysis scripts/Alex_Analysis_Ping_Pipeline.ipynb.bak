   "source": [
    "## plot_volcanoes\n",
    "# Per-SAAP RAAS-vs-CTRL volcano, one panel per disease comparison\n",
    "def plot_volcanoes(stats, cohort_name, neuro, use_fdr=False, log2fc_thresh=min_abs_log2fc):\n",
    "    val_col = 'FDR' if use_fdr else 'p_value'\n",
    "    sig_thresh = 0.01 if use_fdr else 0.05\n",
    "    ylab = r'$-\\log_{10}$(FDR)' if use_fdr else r'$-\\log_{10}$(p)'\n",
    "    cmps = [c for c in neuro if c in stats['comparison'].unique()]\n",
    "    n = len(cmps)\n",
    "    fig, axes = plt.subplots(1, n, figsize=(n * 3.2, 3.6), sharey=False)\n",
    "    if n == 1: axes = [axes]\n",
    "    for ax, cmp in zip(axes, cmps):\n",
    "        d = stats[stats['comparison'] == cmp].dropna(subset=[val_col, 'mean_log2FC']).copy()\n",
    "        d['y'] = -np.log10(d[val_col].clip(lower=1e-300))\n",
    "        up = (d[val_col] <= sig_thresh) & (d['mean_log2FC'] >= log2fc_thresh)\n",
    "        down = (d[val_col] <= sig_thresh) & (d['mean_log2FC'] <= -log2fc_thresh)\n",
    "        color = np.where(up, COLOR_UP, np.where(down, COLOR_DOWN, COLOR_NS))\n",
    "        ax.scatter(d['mean_log2FC'], d['y'], c=color, s=14, alpha=0.8, edgecolor='none')\n",
    "        ax.axvline(log2fc_thresh, color='gray', ls='--', lw=0.7)\n",
    "        ax.axvline(-log2fc_thresh, color='gray', ls='--', lw=0.7)\n",
    "        ax.axhline(-np.log10(sig_thresh), color='gray', ls='--', lw=0.7)\n",
    "        ax.set_title(f'{cmp} vs CTRL', fontsize=11)\n",
    "        ax.set_xlabel(r'log$_2$(FoldChange)', fontsize=10)\n",
    "        ax.annotate(f'↑{int(up.sum())}', xy=(0.97, 0.96), xycoords='axes fraction',\n",
    "                    ha='right', va='top', color=COLOR_UP, fontsize=10, fontweight='bold')\n",
    "        ax.annotate(f'↓{int(down.sum())}', xy=(0.03, 0.96), xycoords='axes fraction',\n",
    "                    ha='left', va='top', color=COLOR_DOWN, fontsize=10, fontweight='bold')\n",
    "        ax.spines['left'].set_visible(True); ax.spines['bottom'].set_visible(True)\n",
    "        ax.tick_params(left=True, bottom=True, length=3, labelsize=9)\n",
    "    axes[0].set_ylabel(ylab, fontsize=10)\n",
    "    fig.suptitle(f'{cohort_name} — SAAP RAAS vs CTRL '\n",
    "                 f'({\"BH-FDR\" if use_fdr else \"nominal p\"} <= {sig_thresh}, '\n",
    "                 f'|log$_2$FC| >= {log2fc_thresh})', fontsize=12)\n",
    "    plt.tight_layout()\n",
    "    fig.savefig(f'{PLOT_DIR}SAAP_volcano_{cohort_name}_{val_col}.pdf', bbox_inches='tight')\n",
    "    plt.show()"
   ]
  },
