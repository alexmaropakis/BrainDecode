   "source": [
    "## plot_aas_volcano\n",
    "# Substitution-type volcano for one comparison\n",
    "def plot_aas_volcano(cohort, log2fc_thresh=min_abs_log2fc, q_cut=q_thresh, label_top=12):\n",
    "    aas_stats, cohort_name = cohort['aas_stats'], cohort['name']\n",
    "    volcano_cmp = cohort['volcano_cmp']\n",
    "    if aas_stats is None or aas_stats.empty:\n",
    "        print(f'[{cohort_name}] no aa_sub stats.'); return\n",
    "    fig, axb = plt.subplots(figsize=(4.5, 4))\n",
    "    d = aas_stats[aas_stats.comparison == volcano_cmp].dropna(subset=['q_value', 'mean_log2FC']).copy()\n",
    "    d['y'] = -np.log10(d['q_value'].clip(lower=1e-300))\n",
    "    sig = (d['q_value'] <= q_cut) & (d['mean_log2FC'].abs() >= log2fc_thresh)\n",
    "    axb.scatter(d.loc[~sig, 'mean_log2FC'], d.loc[~sig, 'y'], s=22, color=COLOR_NSIG,\n",
    "                alpha=0.75, edgecolor='none', label='Not significant')\n",
    "    axb.scatter(d.loc[sig, 'mean_log2FC'], d.loc[sig, 'y'], s=22, color=COLOR_SIG,\n",
    "                alpha=0.9, edgecolor='none', label='Significant')\n",
    "    for _, r in d[sig].sort_values('y', ascending=False).head(label_top).iterrows():\n",
    "        axb.annotate(r['aa_sub'].replace(' to ', '→'), xy=(r['mean_log2FC'], r['y']),\n",
    "                     xytext=(6, 2), textcoords='offset points', fontsize=7,\n",
    "                     arrowprops=dict(arrowstyle='-', lw=0.4, color='gray'))\n",
    "    axb.set_xlabel(r'log$_2$[RAAS$_{%s}$/RAAS$_{CTRL}$]' % volcano_cmp, fontsize=11)\n",
    "    axb.set_ylabel(r'$-\\log_{10}$[q]', fontsize=11)\n",
    "    axb.set_title(f'{cohort_name}: {volcano_cmp} vs CTRL', fontsize=12)\n",
    "    axb.legend(fontsize=8, frameon=False, loc='upper left')\n",
    "    axb.spines['left'].set_visible(True); axb.spines['bottom'].set_visible(True)\n",
    "    axb.tick_params(left=True, bottom=True, length=3, labelsize=9)\n",
    "    plt.tight_layout()\n",
    "    fig.savefig(f'{PLOT_DIR}AAS_volcano_{cohort_name}_{volcano_cmp}.pdf', bbox_inches='tight')\n",
    "    plt.show()"
   ]
  },
