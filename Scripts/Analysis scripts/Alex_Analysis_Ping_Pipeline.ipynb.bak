    "## Analysis configuration — constants shared across the helper functions below\n",
    "\n",
    "# columns / grouping\n",
    "raas_col = 'Reporter_RAAS'          # RAAS column used for most analyses\n",
    "ctrl_label = 'CTRL'\n",
    "disease_order = ['CTRL', 'AD', 'PD', 'ADPD']\n",
    "SAAP_KEYS = ['MTP_seq', 'BP_seq', 'aa_sub']\n",
    "\n",
    "# amino acid ordering for standardized plotting\n",
    "aa_order = ['G', 'A', 'V', 'L', 'I', 'M', 'P', 'F', 'Y', 'W',\n",
    "            'S', 'T', 'C', 'N', 'Q', 'D', 'E', 'K', 'R', 'H']\n",
    "\n",
    "## significance thresholds\n",
    "min_saap = 3            # min SAAPs per aa_sub for Friedman / Wilcoxon subtype tests\n",
    "min_saap_per_aas = 3    # min qualifying SAAPs per AAS for tissue fold-change heatmaps\n",
    "min_reps = 2            # min replicates per group for disease-vs-CTRL t-tests\n",
    "min_abs_log2fc = 0.5    # |log2FC| threshold for significant heatmaps\n",
    "fdr_thresh = 0.01       # BH-FDR threshold (subtype analysis)\n",
    "q_thresh = 0.01         # significance cutoff for the aa_sub volcano\n",
    "sel_metric = 'p_value'  # SAAP-level heatmap selection metric\n",
    "sel_thresh = 0.05\n",
    "volcano_use_fdr = False\n",
    "scatter_agg = 'mean'    # per-SAAP collapse for the substitution scatter\n",
    "\n",
    "## colors & colormap\n",
    "cmap = LinearSegmentedColormap.from_list(\n",
    "    'pinky_RAAS', ['#027FC1', '#F8D7A7', '#FD7E81'], N=256)   # low -> mid -> high\n",
    "COLOR_UP, COLOR_DOWN, COLOR_NS = '#C0527A', '#4A90C4', '#CCCCCC'\n",
    "COLOR_SIG, COLOR_NSIG = '#E8883A', '#3B6FB0'                  # aa_sub volcano: orange / blue\n",
    "DISEASE_COLORS = {'CTRL': '#9AA0A6', 'AD': '#C0527A', 'PD': '#4A90C4', 'ADPD': '#7B5EA7'}"
   ]
  },
