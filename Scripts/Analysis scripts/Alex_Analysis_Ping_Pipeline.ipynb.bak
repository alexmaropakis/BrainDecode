    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.stats import friedmanchisquare, wilcoxon\n",
    "from statsmodels.stats.multitest import multipletests\n",
    "from matplotlib.colors import LinearSegmentedColormap\n",
    "\n",
    "# ── Data prep ───────────────────────────────────────────────────────────────\n",
    "sub_df = replicate_cols(SAAP_quant_df_pooled)\n",
    "sub_df['log10_RAAS'] = sub_df[raas_col]\n",
    "sub_df = sub_df.replace([np.inf, -np.inf], np.nan).dropna(subset=['log10_RAAS'])\n",
    "\n",
    "# ── Run ─────────────────────────────────────────────────────────────────────\n",
    "brain_df = sub_df[sub_df['Dataset'] == 'brain'].copy()\n",
    "\n",
    "analyze_cohort(brain_df, 'Brain')"
   ]
