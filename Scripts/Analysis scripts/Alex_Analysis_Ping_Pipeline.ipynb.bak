   "source": [
    "## analyze_cohort\n",
    "# Per-cohort subtype analysis: Friedman (complete SAAPs) + pairwise Wilcoxon (partial)\n",
    "def analyze_cohort(cohort_df, cohort_name):\n",
    "    plot_df = cohort_df.copy()\n",
    "    diseases = [d for d in disease_order if d in plot_df['Disease'].unique()]\n",
    "    neuro = [d for d in diseases if d != ctrl_label]\n",
    "\n",
    "    # Median RAAS per unique SAAP within disease, then SAAP x disease matrix\n",
    "    saap_keys = ['Disease', 'MTP_seq', 'BP_seq', 'aa_sub']\n",
    "    saap_median = (plot_df.groupby(saap_keys, observed=True)['log10_RAAS']\n",
    "                   .median().reset_index(name='med'))\n",
    "    saap_median['SAAP_ID'] = (saap_median[['MTP_seq', 'BP_seq', 'aa_sub']]\n",
    "                              .astype(str).agg('|'.join, axis=1))\n",
    "\n",
    "    wide = (saap_median.pivot_table(index=['aa_sub', 'SAAP_ID'], columns='Disease',\n",
    "                                    values='med', observed=True)\n",
    "            .reindex(columns=diseases))\n",
    "\n",
    "    # Presence-based SAAP partition (no overlap between the two analyses)\n",
    "    complete_mask = wide[diseases].notna().all(axis=1)\n",
    "    incomplete_mask = (wide[ctrl_label].notna()\n",
    "                       & wide[neuro].notna().any(axis=1)\n",
    "                       & ~complete_mask)\n",
    "\n",
    "    # ════════════════════════════════════════════════════════════════════════\n",
    "    # ANALYSIS 1 — Friedman: SAAPs present in ALL disease groups\n",
    "    # Non-parametric repeated-measures; each SAAP is a block across conditions.\n",
    "    # ════════════════════════════════════════════════════════════════════════\n",
    "    complete = wide[complete_mask]\n",
    "    rows = []\n",
    "    for aa_sub, block in complete.groupby(level='aa_sub'):\n",
    "        if len(block) < min_saap:\n",
    "            continue\n",
    "        try:\n",
    "            stat, p = friedmanchisquare(*[block[d].values for d in diseases])\n",
    "        except ValueError:\n",
    "            continue\n",
    "        rows.append({'aa_sub': aa_sub, 'n_saap': len(block),\n",
    "                     'friedman_stat': stat, 'pval': p})\n",
    "\n",
    "    fried_df = pd.DataFrame(rows)\n",
    "    if not fried_df.empty:\n",
    "        fried_df = run_fdr(fried_df, p_col='pval')\n",
    "        fried_df['Significance'] = fried_df['FDR'].apply(add_sig_label)\n",
    "\n",
    "        # log2FC vs CTRL per (aa_sub, disease) from complete SAAPs\n",
    "        aas_med = complete.groupby(level='aa_sub').median()\n",
    "        fc1 = aas_med.sub(aas_med[ctrl_label], axis=0) * np.log2(10)\n",
    "        fried_df['max_abs_log2FC'] = fried_df['aa_sub'].map(fc1[neuro].abs().max(axis=1))\n",
    "        fried_df = fried_df.sort_values(['FDR', 'pval'])\n",
    "        fried_df.to_csv(f'{PLOT_DIR}friedman_complete_SAAPs_{cohort_name}.tsv',\n",
    "                        sep='\\t', index=False)\n",
    "\n",
    "        sig1 = fried_df[(fried_df['FDR'] < fdr_thresh)\n",
    "                        & (fried_df['max_abs_log2FC'] >= min_abs_log2fc)]['aa_sub'].tolist()\n",
    "        print(f'[{cohort_name}] Friedman tested: {len(fried_df)} | '\n",
    "              f'FDR<{fdr_thresh} & |log2FC|>={min_abs_log2fc}: {len(sig1)}')\n",
    "\n",
    "        order1 = (fc1.loc[sig1, neuro].mean(axis=1).sort_values(ascending=False).index\n",
    "                  if sig1 else [])\n",
    "        mat1 = fc1.reindex(index=order1, columns=diseases)\n",
    "        plot_subtype_sig_heatmap(mat1, cohort_name, 'Friedman (complete SAAPs)',\n",
    "                         'Disease', f'friedman_complete_heatmap_{cohort_name}.pdf')\n",
    "    else:\n",
    "        print(f'[{cohort_name}] Friedman: no aa_sub with complete blocks.')\n",
    "\n",
    "    # ════════════════════════════════════════════════════════════════════════\n",
    "    # ANALYSIS 2 — Pairwise Wilcoxon: SAAPs in CTRL + >=1 neurodegen, NOT all.\n",
    "    # Each neurodegen group vs CTRL on shared SAAPs (paired, non-parametric);\n",
    "    # an aa_sub is significant if >=1 comparison qualifies.\n",
    "    # ════════════════════════════════════════════════════════════════════════\n",
    "    incomplete = wide[incomplete_mask]\n",
    "    rows = []\n",
    "    for aa_sub, block in incomplete.groupby(level='aa_sub'):\n",
    "        for g in neuro:\n",
    "            pair = block[[ctrl_label, g]].dropna()\n",
    "            if len(pair) < min_saap:\n",
    "                continue\n",
    "            if np.all(pair[g].values - pair[ctrl_label].values == 0):\n",
    "                continue\n",
    "            try:\n",
    "                stat, p = wilcoxon(pair[ctrl_label].values, pair[g].values)\n",
    "            except ValueError:\n",
    "                continue\n",
    "            log2fc = (np.median(pair[g].values)\n",
    "                      - np.median(pair[ctrl_label].values)) * np.log2(10)\n",
    "            rows.append({'aa_sub': aa_sub, 'comparison': f'{g}_vs_{ctrl_label}',\n",
    "                         'n_pairs': len(pair), 'wilcoxon_stat': stat,\n",
    "                         'pval': p, 'log2FC_vs_CTRL': log2fc})\n",
    "\n",
    "    pair_df = pd.DataFrame(rows)\n",
    "    if not pair_df.empty:\n",
    "        pair_df = run_fdr(pair_df, p_col='pval')\n",
    "        pair_df['Significance'] = pair_df['FDR'].apply(add_sig_label)\n",
    "        pair_df = pair_df.sort_values(['FDR', 'pval'])\n",
    "        pair_df.to_csv(f'{PLOT_DIR}pairwise_partial_SAAPs_{cohort_name}.tsv',\n",
    "                       sep='\\t', index=False)\n",
    "\n",
    "        qualifying = pair_df[(pair_df['FDR'] < fdr_thresh)\n",
    "                             & (pair_df['log2FC_vs_CTRL'].abs() >= min_abs_log2fc)]\n",
    "        sig2 = qualifying['aa_sub'].unique().tolist()\n",
    "        print(f'[{cohort_name}] Pairwise comparisons: {len(pair_df)} | '\n",
    "              f'aa_subs with >=1 qualifying comparison: {len(sig2)}')\n",
    "\n",
    "        mat2 = (pair_df[pair_df['aa_sub'].isin(sig2)]\n",
    "                .pivot_table(index='aa_sub', columns='comparison',\n",
    "                             values='log2FC_vs_CTRL', observed=True)\n",
    "                .reindex(columns=[f'{g}_vs_{ctrl_label}' for g in neuro]))\n",
    "        if not mat2.empty:\n",
    "            mat2 = mat2.reindex(index=mat2.mean(axis=1).sort_values(ascending=False).index)\n",
    "        plot_subtype_sig_heatmap(mat2, cohort_name, 'Pairwise Wilcoxon (partial SAAPs)',\n",
    "                         'Comparison', f'pairwise_partial_heatmap_{cohort_name}.pdf')\n",
    "    else:\n",
    "        print(f'[{cohort_name}] Pairwise: no aa_sub with partial-presence SAAPs.')"
   ]
  },
