      "fcb4\n",
      "fcb5\n",
      "{'Main peptides': np.int64(925437), 'DP': np.int64(95887), 'PTM': np.int64(39582), 'AAS': np.int64(2309), 'Non-homologous': np.int64(2309), 'High-confidence': np.int64(2090), 'Validated': np.int64(1382)}\n"
