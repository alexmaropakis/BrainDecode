', 'GILAADESCGSIAK', 'GILAADESCGSIAK', 'GILAADESCGSIAK', 'LAQEGGWGVMVSHR', 'AGVAAPATQVVQVTLQSVQR', 'AGVAAPATQVVQVTLQSVQR', 'AGVAAPATQVVQVTLQSVQR', 'AGVAAPATQVVQVTLQSVQR', 'AGVAAPATQVVQVTLQSVQR', 'AGVAAPATQVVQVTLQSVQR', 'AGVAAPATQVVQVTLQSVQR', 'EDDAALEK', 'EDDAALEK', 'EDDAALEK', 'EDDAALEK', 'EDDAALEK', 'EDDAALEK', 'EDDAALEK', 'EDDAALEK', 'EANALAAGHPAQAAAINAR', 'EANALAAGHPAQAAAINAR', 'EANALAAGHPAQAAAINAR', 'EANALAAGHPAQAAAINAR', 'EANALAAGHPAQAAAINAR', 'EANALAAGHPAQAAAINAR', 'EANALAAGHPAQAAAINAR', 'EANALAAGHPAQAAAINAR', 'FDGALMVDLTEFQTNLVPYPR', 'FDGALMVDLTEFQTNLVPYPR', 'FDGALMVDLTEFQTNLVPYPR', 'FDGALMVDLTEFQTNLVPYPR', 'FDGALMVDLTEFQTNLVPYPR', 'FDGALMVDLTEFQTNLVPYPR', 'FDGALMVDLTEFQTNLVPYPR', 'FDGALMVDLTEFQTNLVPYPR', 'LCYVALDFENEMTTAASSSSLEK', 'LCYVALDFENEMTTAASSSSLEK', 'LCYVALDFENEMTTAASSSSLEK', 'LCYVALDFENEMTTAASSSSLEK', 'LCYVALDFENEMTTAASSSSLEK', 'LCYVALDFENEMTTAASSSSLEK', 'LCYVALDFENEMTTAASSSSLEK', 'LCYVALDFENEMTTAASSSSLEK', 'AGEGDATIHLK', 'AGEGDATIHLK', 'AGEGDATIHLK', 'AGEGDATIHLK', 'AGEGDATIHLK', 'AGEGDATIHLK', 'AGEGDATIHLK', 'AGEGDATIHLK']\n",
