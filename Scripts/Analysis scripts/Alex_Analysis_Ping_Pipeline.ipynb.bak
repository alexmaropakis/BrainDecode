    "## plot_subtype_sig_heatmap\n",
    "# Heatmap of significant aa_sub log2(RAAS/CTRL) (Friedman / Wilcoxon)\n",
    "def plot_subtype_sig_heatmap(matrix, cohort_name, analysis_name, col_label, fname):\n",
    "    if matrix.empty or matrix.dropna(how='all').empty:\n",
    "        print(f'[{cohort_name}] {analysis_name}: no significant aa_sub to plot.')\n",
    "        return\n",
    "    max_abs = np.nanmax(np.abs(matrix.values))\n",
    "    plt.figure(figsize=(1.5 + matrix.shape[1] * 1.6, max(6, matrix.shape[0] * 0.5)))\n",
    "    plt.imshow(matrix, aspect='auto', cmap=cmap, vmin=-max_abs, vmax=max_abs)\n",
    "    cbar = plt.colorbar(label=r'log$_2$(median RAAS / CTRL)')\n",
    "    cbar.ax.tick_params(labelsize=16)\n",
    "    cbar.ax.set_ylabel(r'log$_2$(median RAAS / CTRL)', size=18)\n",
    "    plt.xticks(np.arange(matrix.shape[1]), matrix.columns, rotation=90, fontsize=16)\n",
    "    plt.yticks(np.arange(matrix.shape[0]), matrix.index, fontsize=16)\n",
    "    plt.xlabel(col_label, fontsize=18)\n",
    "    plt.ylabel('AA Substitution', fontsize=18)\n",
    "    plt.title(f'{cohort_name}: {analysis_name}\\n'\n",
    "              f'(BH-FDR < {fdr_thresh}, |log$_2$FC| $\\\\geq$ {min_abs_log2fc})', fontsize=15)\n",
    "    plt.tight_layout()\n",
    "    plt.tick_params(axis='both', length=5)\n",
    "    plt.grid(False)\n",
    "    plt.savefig(f'{PLOT_DIR}{fname}', bbox_inches='tight')\n",
    "    plt.show()"
   ]
  },
