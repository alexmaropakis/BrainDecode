    "    \"\"\"\n",
    "    val_mtp_dict = pickle.load(open(data_dir+'Ion_validated_MTP_dict.p', 'rb'))\n",
    "    s_seqs = list(val_mtp_dict[s]['mistranslated sequence'].values())\n",
    "    s_seqs = list(set(s_seqs))\n",
    "    n_seqs = len(s_seqs)\n",
    "    return(n_seqs)"
   ]
