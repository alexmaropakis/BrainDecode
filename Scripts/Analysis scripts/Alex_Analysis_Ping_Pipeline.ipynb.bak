   "source": [
    "# ANOVA factors of RAAS variation: substitution type (AAS), disease, and tissue.\n",
    "# One-way ANOVA F-statistic of Reporter_RAAS across the levels of each factor;\n",
    "# one bar per factor (higher F = more of the RAAS variance explained).\n",
    "factor_cols = {'AAS': 'aa_sub', 'Disease': 'Disease', 'Tissue': 'Tissue'}\n",
    "\n",
    "anova_src = replicate_cols(SAAP_quant_df_grouped)\n",
    "anova_src = anova_src.replace([np.inf, -np.inf], np.nan).dropna(subset=[raas_col])\n",
    "n_obs = anova_src.shape[0]\n",
    "\n",
    "factor_F, factor_p = {}, {}\n",
    "for label, col in factor_cols.items():\n",
    "    groups = [g[raas_col].dropna().values\n",
    "              for _, g in anova_src.groupby(col, observed=True)\n",
    "              if g[raas_col].dropna().shape[0] >= 2]\n",
    "    F, p = stats.f_oneway(*groups)\n",
    "    factor_F[label], factor_p[label] = F, p\n",
    "\n",
    "# Order bars by increasing F so the strongest factor sits on the right (as in ref).\n",
    "order = sorted(factor_cols, key=lambda k: factor_F[k])\n",
    "greys = {0: '#d9d9d9', 1: '#969696', 2: '#525252'}   # light -> dark by rank\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(4.5, 4.5))\n",
    "for i, label in enumerate(order):\n",
    "    ax.bar(i, factor_F[label], color=greys[i], width=0.7)\n",
    "\n",
    "handles = [mpatches.Patch(color=greys[i], label=fmt_p(factor_p[label]))\n",
    "           for i, label in enumerate(order)]\n",
    "ax.legend(handles=handles, frameon=False, fontsize=10, loc='upper left')\n",
    "\n",
    "ax.set_xticks(range(len(order)))\n",
    "ax.set_xticklabels(order, fontsize=12)\n",
    "ax.set_ylabel('ANOVA $F$-statistic', fontsize=13)\n",
    "ax.set_title(f'Factors of RAAS variation (ANOVA, n = {n_obs:,},\\nP values from F-tests)',\n",
    "             fontsize=12)\n",
    "ax.spines['left'].set_visible(True); ax.spines['bottom'].set_visible(True)\n",
    "ax.tick_params(left=True, bottom=True, length=3, labelsize=10)\n",
    "plt.tight_layout()\n",
    "fig.savefig(f'{PLOT_DIR}ANOVA_F_by_factor.pdf', bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
