    "## classify_sub\n",
    "# Label a substitution conservative / nonconservative by AA biochemical group\n",
    "def classify_sub(sub):\n",
    "    aa1,aa2 = sub.split(' to ')\n",
    "\n",
    "    if aa_groups[aa1] == aa_groups[aa2]:\n",
    "        return 'Conservative'\n",
    "    else:\n",
    "        return 'Nonconservative'"
