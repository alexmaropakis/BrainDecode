   "source": [
    "## plot_sig_heatmap\n",
    "# Heatmap of significant-SAAP per-disease mean log2(RAAS/CTRL)\n",
    "def plot_sig_heatmap(matrix, cohort_name):\n",
    "    if matrix.empty or matrix.dropna(how='all').empty:\n",
    "        print(f'[{cohort_name}] nothing to plot.'); return\n",
    "    n_rows, n_cols = matrix.shape\n",
    "    max_abs = np.nanmax(np.abs(matrix.values))\n",
    "    row_h = 0.4 if n_rows < 40 else (0.22 if n_rows < 120 else 0.12)\n",
    "    yfs = 9 if n_rows < 40 else (6 if n_rows < 120 else 4)\n",
    "    fig, ax = plt.subplots(figsize=(2 + n_cols * 1.4, max(5, n_rows * row_h)))\n",
    "    im = ax.imshow(matrix, aspect='auto', cmap=cmap, vmin=-max_abs, vmax=max_abs)\n",
    "    ax.set_xticks(np.arange(n_cols)); ax.set_xticklabels(matrix.columns, rotation=0, fontsize=12)\n",
    "    ax.set_yticks(np.arange(n_rows)); ax.set_yticklabels(matrix.index, fontsize=yfs)\n",
    "    ax.tick_params(length=0)\n",
    "    for s in ax.spines.values(): s.set_visible(False)\n",
    "    ax.set_title(cohort_name, fontsize=12, pad=10)\n",
    "    cbar = fig.colorbar(im, ax=ax, fraction=0.025, pad=0.02, shrink=0.3, aspect=12,\n",
    "                        ticks=[-max_abs, 0, max_abs])\n",
    "    cbar.ax.set_yticklabels([f'{-max_abs:.0f}', '0', f'{max_abs:.0f}'])\n",
    "    cbar.ax.tick_params(length=0, labelsize=10); cbar.outline.set_visible(False)\n",
    "    plt.tight_layout()\n",
    "    fig.savefig(f'{PLOT_DIR}SAAP_replicate_significant_heatmap_{cohort_name}.pdf', bbox_inches='tight')\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
