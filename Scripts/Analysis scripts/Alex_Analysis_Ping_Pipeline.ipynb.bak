   "source": [
    "### Substitution & Disease Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 121,
   "id": "2df6f2c8",
   "metadata": {},
   "outputs": [],
   "source": [
    "## prep\n",
    "# Add replicate columns and a log10_RAAS column; drop non-finite RAAS\n",
    "def prep(df):\n",
    "    df = replicate_cols(df)\n",
    "    df['log10_RAAS'] = df[raas_col]\n",
    "    return df.replace([np.inf, -np.inf], np.nan).dropna(subset=['log10_RAAS'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 122,
   "id": "8c5b1b08",
   "metadata": {},
   "outputs": [],
   "source": [
    "## normalize_logfc\n",
    "# Per-SAAP log2FC of each replicate vs the CTRL mean\n",
    "def normalize_logfc(cohort_df):\n",
    "    # Per-SAAP log2 fold change of each replicate relative to the CTRL mean.\n",
    "    df = cohort_df.copy()\n",
    "    ctrl_means = (df[df['Disease'] == ctrl_label].groupby(SAAP_KEYS)['log10_RAAS']\n",
    "                  .mean().rename('ctrl_mean').reset_index())\n",
    "    df = df.merge(ctrl_means, on=SAAP_KEYS, how='left')\n",
    "    df['log2FC'] = (df['log10_RAAS'] - df['ctrl_mean']) * np.log2(10)\n",
    "    return df.dropna(subset=['log2FC'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 123,
   "id": "39026c45",
   "metadata": {},
   "outputs": [],
   "source": [
    "## compute_stats\n",
    "# Per-SAAP Welch t-test (each disease vs CTRL) + BH-FDR per comparison\n",
    "def compute_stats(cohort_df):\n",
    "    # Per-SAAP Welch t-test (each disease vs CTRL), BH-FDR within each comparison.\n",
    "    diseases = [d for d in disease_order if d in cohort_df['Disease'].unique()]\n",
    "    neuro = [d for d in diseases if d != ctrl_label]\n",
    "    frames = []\n",
    "    for cmp in neuro:\n",
    "        rows = []\n",
    "        for keys, grp in cohort_df.groupby(SAAP_KEYS, observed=True):\n",
    "            ctrl_v = grp.loc[grp['Disease'] == ctrl_label, 'log10_RAAS'].dropna().values\n",
    "            cmp_v = grp.loc[grp['Disease'] == cmp, 'log10_RAAS'].dropna().values\n",
    "            if len(ctrl_v) < min_reps or len(cmp_v) < min_reps:\n",
    "                continue\n",
    "            _, p = ttest_ind(cmp_v, ctrl_v, equal_var=False)\n",
    "            log2fc = (np.mean(cmp_v) - np.mean(ctrl_v)) * np.log2(10)\n",
    "            rows.append({'MTP_seq': keys[0], 'BP_seq': keys[1], 'aa_sub': keys[2],\n",
    "                         'comparison': cmp, 'mean_log2FC': log2fc, 'p_value': p})\n",
    "        cdf = pd.DataFrame(rows)\n",
    "        if not cdf.empty:\n",
    "            cdf = run_fdr(cdf, p_col='p_value', out_col='FDR')\n",
    "        frames.append(cdf)\n",
    "    return (pd.concat(frames, ignore_index=True) if frames else pd.DataFrame()), neuro"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 124,
   "id": "e1ac313e",
   "metadata": {},
   "outputs": [],
   "source": [
    "## compute_aas_stats\n",
    "# Substitution-type Welch t-test vs CTRL + BH-FDR per comparison\n",
    "def compute_aas_stats(cohort_df):\n",
    "    # Substitution-type (aa_sub) Welch t-test vs CTRL + BH-FDR (two-sided).\n",
    "    diseases = [d for d in disease_order if d in cohort_df['Disease'].unique()]\n",
    "    neuro = [d for d in diseases if d != ctrl_label]\n",
    "    frames = []\n",
    "    for cmp in neuro:\n",
    "        rows = []\n",
    "        for aas, grp in cohort_df.groupby('aa_sub', observed=True):\n",
    "            ctrl_v = grp.loc[grp['Disease'] == ctrl_label, 'log10_RAAS'].dropna().values\n",
    "            cmp_v = grp.loc[grp['Disease'] == cmp, 'log10_RAAS'].dropna().values\n",
    "            if len(ctrl_v) < min_reps or len(cmp_v) < min_reps:\n",
    "                continue\n",
    "            _, p = ttest_ind(cmp_v, ctrl_v, equal_var=False)\n",
    "            log2fc = (np.mean(cmp_v) - np.mean(ctrl_v)) * np.log2(10)\n",
    "            rows.append({'aa_sub': aas, 'comparison': cmp, 'mean_log2FC': log2fc, 'p_value': p})\n",
    "        cdf = pd.DataFrame(rows)\n",
    "        if not cdf.empty:\n",
    "            cdf = run_fdr(cdf, p_col='p_value', out_col='q_value')\n",
    "        frames.append(cdf)\n",
    "    return pd.concat(frames, ignore_index=True) if frames else pd.DataFrame()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 125,
   "id": "8b363d25",
   "metadata": {},
   "outputs": [],
   "source": [
    "## build_cohort\n",
    "# Compute and cache the SAAP-level (and optional aa_sub) stats for one cohort\n",
    "def build_cohort(cohort_df, cohort_name, with_aas=False):\n",
    "    # Compute (and cache) the stats every downstream block needs for one cohort.\n",
    "    stats, neuro = compute_stats(cohort_df)\n",
    "    if not stats.empty:\n",
    "        stats['SAAP'] = stats['aa_sub'] + ' | ' + stats['MTP_seq']\n",
    "        stats.to_csv(f'{PLOT_DIR}SAAP_replicate_ttest_{cohort_name}.tsv', sep='\\t', index=False)\n",
    "    entry = {'df': cohort_df, 'name': cohort_name, 'stats': stats, 'neuro': neuro,\n",
    "             'aas_stats': None, 'highlight_aas': None, 'volcano_cmp': None}\n",
    "    if with_aas:\n",
    "        aas_stats = compute_aas_stats(cohort_df)\n",
    "        if not aas_stats.empty:\n",
    "            aas_stats.to_csv(f'{PLOT_DIR}AAS_ttest_{cohort_name}.tsv', sep='\\t', index=False)\n",
    "            strongest = aas_stats.loc[aas_stats['q_value'].idxmin()]   # auto-pick top signal\n",
    "            entry['highlight_aas'] = strongest['aa_sub']\n",
    "            entry['volcano_cmp'] = strongest['comparison']\n",
    "        entry['aas_stats'] = aas_stats\n",
    "    return entry"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 126,
   "id": "ca345da8",
   "metadata": {},
   "outputs": [],
   "source": [
    "## heatmap_for\n",
    "# Build the significant-SAAP matrix for a cohort and draw its heatmap\n",
    "def heatmap_for(cohort):\n",
    "    # Significant-SAAP matrix: per-disease mean log2(RAAS/CTRL), sorted by neuro mean.\n",
    "    cohort_df, cohort_name, stats, neuro = (cohort['df'], cohort['name'],\n",
    "                                            cohort['stats'], cohort['neuro'])\n",
    "    if stats.empty:\n",
    "        print(f'[{cohort_name}] no testable SAAPs.'); return\n",
    "    sig = stats[(stats[sel_metric] <= sel_thresh) & (stats['mean_log2FC'].abs() >= min_abs_log2fc)]\n",
    "    sig_saaps = sig['SAAP'].unique().tolist()\n",
    "    if not sig_saaps:\n",
    "        print(f'[{cohort_name}] none pass {sel_metric}<={sel_thresh}; no heatmap.'); return\n",
    "    norm = normalize_logfc(cohort_df)\n",
    "    norm['SAAP'] = norm['aa_sub'] + ' | ' + norm['MTP_seq']\n",
    "    matrix = (norm[norm['SAAP'].isin(sig_saaps)]\n",
    "              .pivot_table(index='SAAP', columns='Disease', values='log2FC', aggfunc='mean')\n",
    "              .reindex(columns=disease_order))\n",
    "    matrix = matrix.reindex(index=matrix[neuro].mean(axis=1).sort_values(ascending=False).index)\n",
    "    print(f'[{cohort_name}] {len(sig_saaps)} SAAPs | '\n",
    "          f'displayed max |log2FC| = {np.nanmax(np.abs(matrix.values)):.1f}')\n",
    "    plot_sig_heatmap(matrix, cohort_name)"
   ]
  },
