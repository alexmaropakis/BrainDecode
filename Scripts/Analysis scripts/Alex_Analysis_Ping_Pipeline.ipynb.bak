    "# 4a. Disease-associated RAAS changes — SETUP + significance heatmaps\n",
    "# Shared setup for the three disease blocks (heatmaps, volcanoes, scatter).\n",
    "# SAAP-level and substitution-type stats are computed once here and cached in\n",
    "# COHORTS so the volcano/scatter blocks reuse them without recomputing.\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.stats import ttest_ind\n",
    "from statsmodels.stats.multitest import multipletests\n",
    "from matplotlib.colors import LinearSegmentedColormap\n",
    "\n",
    "# ── Global style ─────────────────────────────────────────────────────────────\n",
    "plt.rcParams.update({\n",
    "    'figure.facecolor': 'white', 'axes.facecolor': 'white', 'savefig.facecolor': 'white',\n",
    "    'axes.spines.top': False, 'axes.spines.right': False,\n",
    "    'axes.spines.left': False, 'axes.spines.bottom': False,\n",
    "    'xtick.bottom': False, 'xtick.top': False, 'ytick.left': False, 'ytick.right': False,\n",
    "})\n",
    "\n",
    "# ── Run: build cohorts once, plot heatmaps for all three ─────────────────────\n",
    "grouped = prep(SAAP_quant_df_grouped)\n",
    "pooled = prep(SAAP_quant_df_pooled)\n",
    "\n",
    "COHORTS = {\n",
    "    'ACG': build_cohort(grouped[grouped['Dataset'] == 'acg'].copy(), 'ACG'),\n",
    "    'FC': build_cohort(grouped[grouped['Dataset'] == 'fc'].copy(), 'FC'),\n",
    "    'Brain': build_cohort(pooled[pooled['Dataset'] == 'brain'].copy(), 'Brain', with_aas=True),\n",
    "}\n",
    "\n",
    "for cohort in COHORTS.values():\n",
    "    heatmap_for(cohort)"
   ]
