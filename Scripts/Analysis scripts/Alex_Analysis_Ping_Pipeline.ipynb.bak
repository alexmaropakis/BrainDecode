   "source": [
    "## plot_aas_scatter\n",
    "# log10[RAAS_CTRL] vs log10[RAAS_disease] scatter for the top substitution\n",
    "def plot_aas_scatter(cohort, agg=scatter_agg, min_pts=min_reps):\n",
    "    cohort_df, cohort_name = cohort['df'], cohort['name']\n",
    "    aas_stats, highlight_aas = cohort['aas_stats'], cohort['highlight_aas']\n",
    "    if aas_stats is None or aas_stats.empty:\n",
    "        print(f'[{cohort_name}] no aa_sub stats.'); return\n",
    "    neuro = cohort['neuro']\n",
    "\n",
    "    fig, axa = plt.subplots(figsize=(4.5, 4))\n",
    "    sub = cohort_df[cohort_df['aa_sub'] == highlight_aas]\n",
    "    per = (sub.groupby(SAAP_KEYS + ['Disease'], observed=True)['log10_RAAS']\n",
    "           .agg(['mean', 'median', 'size']).reset_index())\n",
    "    val = per.pivot_table(index=SAAP_KEYS, columns='Disease', values=agg)\n",
    "    cnt = per.pivot_table(index=SAAP_KEYS, columns='Disease', values='size')\n",
    "    pooled_xy = []\n",
    "    for d in neuro:\n",
    "        if ctrl_label not in cnt.columns or d not in cnt.columns:\n",
    "            continue\n",
    "        m = (cnt[ctrl_label] >= min_pts) & (cnt[d] >= min_pts)\n",
    "        x = val.loc[m, ctrl_label].values; y = val.loc[m, d].values\n",
    "        ok = ~(np.isnan(x) | np.isnan(y)); x, y = x[ok], y[ok]\n",
    "        pooled_xy += [x, y]\n",
    "        q = aas_stats[(aas_stats.aa_sub == highlight_aas) & (aas_stats.comparison == d)]['q_value']\n",
    "        qlab = f', q={q.iloc[0]:.1e}' if len(q) else ''\n",
    "        axa.scatter(x, y, s=22, alpha=0.7, color=DISEASE_COLORS.get(d), edgecolor='none',\n",
    "                    label=f'{d}{qlab}')\n",
    "    if pooled_xy:\n",
    "        allv = np.concatenate(pooled_xy); lo, hi = np.nanmin(allv), np.nanmax(allv)\n",
    "        axa.plot([lo, hi], [lo, hi], color='red', ls='--', lw=1.5)\n",
    "    axa.set_xlabel(r'log$_{10}$[RAAS$_{CTRL}$]', fontsize=11)\n",
    "    axa.set_ylabel(r'log$_{10}$[RAAS$_{disease}$]', fontsize=11)\n",
    "    axa.set_title(highlight_aas.replace(' to ', '→'), fontsize=12)\n",
    "    axa.legend(fontsize=8, frameon=False, loc='lower right')\n",
    "    axa.spines['left'].set_visible(True); axa.spines['bottom'].set_visible(True)\n",
    "    axa.tick_params(left=True, bottom=True, length=3, labelsize=9)\n",
    "    plt.tight_layout()\n",
    "    fig.savefig(f'{PLOT_DIR}AAS_scatter_{cohort_name}_{cohort[\"volcano_cmp\"]}.pdf', bbox_inches='tight')\n",
    "    plt.show()"
   ]
  },
