   "outputs": [],
   "source": [
    "## plot_cohort_heatmap\n",
    "# Tissue x disease heatmap of median RAAS log2FC vs tissue-specific CTRL\n",
    "def plot_cohort_heatmap(cohort_df, cohort_name):\n",
    "    tissue_order = sorted(cohort_df['Tissue'].dropna().unique())\n",
    "\n",
    "    plot_df = cohort_df.copy()\n",
    "    plot_df['Tissue'] = pd.Categorical(plot_df['Tissue'], categories=tissue_order, ordered=True)\n",
    "    plot_df['Disease'] = pd.Categorical(plot_df['Disease'], categories=disease_order, ordered=True)\n",
    "\n",
    "    # Median RAAS per unique SAAP within tissue + disease\n",
    "    saap_keys = ['Tissue', 'Disease', 'MTP_seq', 'BP_seq', 'aa_sub']\n",
    "    saap_median_df = (plot_df.groupby(saap_keys, observed=False)['log10_RAAS']\n",
    "                      .median().reset_index(name='SAAP_median_log10_RAAS'))\n",
    "\n",
    "    # Keep only AAS with enough qualifying SAAPs within tissue + disease\n",
    "    aas_counts = (saap_median_df.groupby(['Tissue', 'Disease', 'aa_sub'], observed=False)\n",
    "                  .size().reset_index(name='n_saap'))\n",
    "    valid_aas = aas_counts[aas_counts['n_saap'] >= min_saap_per_aas][['Tissue', 'Disease', 'aa_sub']]\n",
    "    saap_median_df = saap_median_df.merge(valid_aas, on=['Tissue', 'Disease', 'aa_sub'], how='inner')\n",
    "\n",
    "    # Median SAAP RAAS within each AAS group\n",
    "    aas_median_df = (saap_median_df.groupby(['Tissue', 'Disease', 'aa_sub'], observed=False)['SAAP_median_log10_RAAS']\n",
    "                     .median().reset_index(name='AAS_median_log10_RAAS'))\n",
    "\n",
    "    # Tissue-specific CTRL baselines\n",
    "    ctrl_df = (aas_median_df[aas_median_df['Disease'] == ctrl_label]\n",
    "               [['Tissue', 'aa_sub', 'AAS_median_log10_RAAS']]\n",
    "               .rename(columns={'AAS_median_log10_RAAS': 'CTRL_AAS_median_log10_RAAS'}))\n",
    "\n",
    "    # Tissue-specific log2 fold change vs CTRL\n",
    "    norm_df = aas_median_df.merge(ctrl_df, on=['Tissue', 'aa_sub'], how='left')\n",
    "    norm_df['log2FC_vs_CTRL'] = ((norm_df['AAS_median_log10_RAAS']\n",
    "                                  - norm_df['CTRL_AAS_median_log10_RAAS']) * np.log2(10))\n",
    "    norm_df = norm_df.dropna(subset=['log2FC_vs_CTRL']).copy()\n",
    "\n",
    "    # Order substitutions from positive to negative mean fold change\n",
    "    sub_order = (norm_df.groupby('aa_sub')['log2FC_vs_CTRL']\n",
    "                 .mean().sort_values(ascending=False).index.tolist())\n",
    "\n",
    "    # Keep tissues grouped together\n",
    "    norm_df['Tissue_Disease'] = norm_df['Tissue'].astype(str) + '_' + norm_df['Disease'].astype(str)\n",
    "    column_order = [f'{t}_{d}' for t in tissue_order for d in disease_order]\n",
    "\n",
    "    heatmap_matrix = (norm_df.pivot(index='aa_sub', columns='Tissue_Disease', values='log2FC_vs_CTRL')\n",
    "                      .reindex(index=sub_order).reindex(columns=column_order))\n",
    "\n",
    "    max_abs = np.nanmax(np.abs(norm_df['log2FC_vs_CTRL'].values))\n",
    "\n",
    "    # Plot\n",
    "    plt.figure(figsize=(15, 30))\n",
    "    plt.imshow(heatmap_matrix, aspect='auto', cmap=cmap, vmin=-max_abs, vmax=max_abs)\n",
    "\n",
    "    cbar = plt.colorbar(label=r'log$_2$(median RAAS / tissue CTRL)')\n",
    "    cbar.ax.tick_params(labelsize=25)\n",
    "    cbar.ax.set_ylabel(r'log$_2$(median RAAS / tissue CTRL)', size=30)\n",
    "\n",
    "    for x in np.arange(len(disease_order), len(column_order), len(disease_order)) - 0.5:\n",
    "        plt.axvline(x, color='white', linewidth=2)\n",
    "\n",
    "    plt.xticks(np.arange(len(column_order)), column_order, rotation=90, fontsize=25)\n",
    "    plt.yticks(np.arange(len(heatmap_matrix.index)), heatmap_matrix.index, fontsize=25)\n",
    "    plt.xlabel('Tissue + Disease', fontsize=30)\n",
    "    plt.ylabel('AA Substitution', fontsize=30)\n",
    "    plt.title(f'{cohort_name}: Median RAAS Fold Change per Tissue Relative to Tissue-specific CTRL',\n",
    "              fontsize=30)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.tick_params(axis='both', length=5)\n",
    "    plt.grid(False)\n",
    "    plt.savefig(f'{PLOT_DIR}top_substitution_log2FC_tissue_specific_CTRL_heatmap_{cohort_name}.pdf',\n",
    "                bbox_inches='tight')\n",
    "    plt.show()"
   ]
  },
