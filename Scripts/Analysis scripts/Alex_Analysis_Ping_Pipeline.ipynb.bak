   "source": [
    "## core_saaps_by_tmt\n",
    "# SAAPs present in at least 3 of the given TMT sets for a tissue\n",
    "def core_saaps_by_tmt(df, tmt_list):\n",
    "    sub = (df[df['Dataset'].isin(tmt_list)][['Dataset', 'MTP_seq']].drop_duplicates())\n",
    "    mat = (sub.assign(present=1).pivot_table(index='MTP_seq',columns='Dataset',values='present',fill_value=0))\n",
    "    # ensure all expected TMT columns exist\n",
    "    mat = mat.reindex(columns=tmt_list, fill_value=0)\n",
    "    # SAAP must appear in ALL TMT sets\n",
    "    # core = mat.index[mat.sum(axis=1) == len(tmt_list)]\n",
    "    core = mat.index[mat.sum(axis=1) >= 3]\n",
    "    return set(core)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 103,
   "id": "33b622d8",
   "metadata": {},
   "outputs": [],
   "source": [
    "## core_saaps_by_disease\n",
    "# SAAPs present in every disease state\n",
    "def core_saaps_by_disease(df, disease_order):\n",
    "    sub = (df[df['Sample Type'].isin(disease_order)][['Sample Type', 'MTP_seq']].drop_duplicates())\n",
    "    mat = (sub.assign(present=1).pivot_table(index='MTP_seq',columns='Sample Type',values='present',fill_value=0))\n",
    "    # ensure all expected disease state columns exist\n",
    "    mat = mat.reindex(columns=disease_order, fill_value=0)\n",
    "    # SAAP must appear in ALL disease states\n",
    "    core = mat.index[mat.sum(axis=1) == len(disease_order)]\n",
    "    return set(core)"
   ]
  },
