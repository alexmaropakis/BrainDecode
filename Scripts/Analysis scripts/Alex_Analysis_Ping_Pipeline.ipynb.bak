    "pos_prob_df_acg = pd.read_csv(DEPDIR+'acg/Position_probability_fragment_ion_data.csv')\n",
    "pos_prob_df_fc = pd.read_csv(DEPDIR+'fc/Position_probability_fragment_ion_data.csv')\n",
